# Bu dosyayi kopyalayip .env olarak kaydet, degerleri buraya yaz.
# Program once bu dosyaya bakar; config.py'ye dokunmana gerek kalmaz.

# Trendyol cookie (F12 > Network > apigw istegi > Request Headers > Cookie)
TRENDYOL_COOKIE=storefrontId=1; language=tr; ...buraya_gercek_cookie...

# Urun detay endpoint'i (F12 > Network > urun sayfasinda productgw iceren istek > Request URL)
# Ornek: https://apigw.trendyol.com/discovery-web-productgw-service/api/productDetail/{product_id}
# {product_id} kismini DEGISTIRME, program oraya ID'yi otomatik girer.
TRENDYOL_DETAIL_URL=https://apigw.trendyol.com/discovery-web-productgw-service/api/productDetail/{product_id}

# Opsiyonel proxy (sirket IP'sini korumak istersen):
# TRENDYOL_PROXY=http://kullanici:sifre@host:port
